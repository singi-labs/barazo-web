# Barazo Web Environment Configuration
# Copy this file to .env.local and fill in your values

# API Configuration
#
# NEXT_PUBLIC_API_URL -- used by the browser for client-side API requests.
#   Local dev: set to the API server URL (e.g., http://localhost:3000)
#   Production (behind Caddy): leave unset -- relative URLs are routed by the reverse proxy
#
# API_INTERNAL_URL -- used by Next.js SSR for server-side API requests.
#   Local dev: set to the API server URL (e.g., http://localhost:3000)
#   Docker: set to Docker service name (e.g., http://barazo-api:3000)
#
NEXT_PUBLIC_API_URL=http://localhost:3000
API_INTERNAL_URL=http://localhost:3000

# Application
NEXT_PUBLIC_APP_NAME=Barazo
NEXT_PUBLIC_APP_URL=http://localhost:3001

# OAuth / AT Protocol
NEXT_PUBLIC_OAUTH_CLIENT_ID=barazo-web

# Optional: Analytics (Phase 3+)
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Optional: Sentry/GlitchTip (Phase 1+)
# SENTRY_DSN=
