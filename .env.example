# Barazo Web Environment Configuration
# Copy this file to .env.local and fill in your values

# API Configuration
# Browser-side requests use relative URLs (empty string) automatically.
# API_INTERNAL_URL is only needed for server-side rendering in Docker.
# For local dev, the default (http://localhost:3000) works out of the box.
# API_INTERNAL_URL=http://localhost:3100

# Application
NEXT_PUBLIC_APP_NAME=Barazo
NEXT_PUBLIC_APP_URL=http://localhost:3001

# OAuth / AT Protocol
NEXT_PUBLIC_OAUTH_CLIENT_ID=barazo-web

# Optional: Analytics (Phase 3+)
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Optional: Sentry/GlitchTip (Phase 1+)
# SENTRY_DSN=
